# PostHog analytics — these are PUBLIC (client-side) values, inlined at BUILD time.
# On Vercel, set them as Build-time Environment Variables (not runtime).

# Required. Your PostHog project API key (safe to expose; it's client-side).
PUBLIC_POSTHOG_PROJECT_TOKEN=phc_zASFaKWak9Q63F8Fz3SeAsNDgTYX6mKcdjfbX2aHnXkk

# Optional. Leave UNSET to route events through the same-origin reverse proxy
# defined in vercel.json (recommended — avoids ad-blockers). Set to
# https://us.i.posthog.com (or the EU host) to send directly to PostHog.
# PUBLIC_POSTHOG_HOST=
