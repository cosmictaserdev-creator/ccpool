---
interface Props {
  command?: string;
  class?: string;
}

const { command = "npx ccpool@latest", class: className = "" } = Astro.props;
---

<div
  class:list={[
    "copy-command border-retro-outline bg-retro-card text-retro-fg flex items-center justify-between gap-3 border-2 px-[14px] py-[9px]",
    className,
  ]}
  data-command={command}
>
  <code class="font-vt text-retro-label select-text whitespace-nowrap tracking-[1px]">
    <span class="text-retro-orange select-none">$</span>{" "}<span class="cmd-text">{command}</span>
  </code>
  <button
    type="button"
    class="copy-trigger font-press text-retro-btn bg-retro-orange flex shrink-0 translate-y-[-2px] cursor-pointer items-center justify-center border-none px-[8px] py-[4px] text-[#0a0a0a] shadow-[4px_4px_0_theme(colors.retro.orange-shadow)] transition-all duration-75 hover:translate-x-[2px] hover:translate-y-[0px] hover:shadow-[2px_2px_0_theme(colors.retro.orange-shadow)] active:translate-x-[4px] active:translate-y-[2px] active:shadow-none"
    aria-label={`Copy ${command} to clipboard`}
  >
    <!-- Copy / check icon (pixel-art, swapped on copy) -->
    <svg
      class="copy-icon h-5 w-5 fill-white"
      viewBox="0 0 16 16"
      shape-rendering="crispEdges"
      aria-hidden="true"
    >
      <path d="M6,2h8v3h-8z M11,5h3v6h-3z M2,6h8v9h-8z"></path>
    </svg>
    <svg
      class="check-icon hidden h-5 w-5 fill-white"
      viewBox="0 0 16 16"
      shape-rendering="crispEdges"
      aria-hidden="true"
    >
      <path
        d="M13,3h2v2h-2z M11,5h2v2h-2z M9,7h2v2h-2z M7,9h2v2h-2z M5,11h2v2h-2z M1,7h2v2h-2z M3,9h2v2h-2z"
      ></path>
    </svg>
  </button>
</div>

<script>
  const COPIED_MS = 1600;

  const wireCopyButtons = () => {
    document.querySelectorAll<HTMLElement>(".copy-command").forEach((box) => {
      if (box.dataset.wired) return;
      box.dataset.wired = "true";

      const trigger = box.querySelector<HTMLButtonElement>(".copy-trigger");
      const copyIcon = box.querySelector<SVGElement>(".copy-icon");
      const checkIcon = box.querySelector<SVGElement>(".check-icon");
      let resetTimer: ReturnType<typeof setTimeout> | undefined;

      trigger?.addEventListener("click", async () => {
        const command = box.dataset.command ?? "";
        try {
          await navigator.clipboard.writeText(command);
        } catch {
          // Fallback for insecure contexts / older browsers.
          const ta = document.createElement("textarea");
          ta.value = command;
          ta.style.position = "fixed";
          ta.style.opacity = "0";
          document.body.appendChild(ta);
          ta.select();
          try {
            document.execCommand("copy");
          } catch {
            /* give up silently */
          }
          ta.remove();
        }

        window.posthog?.capture("install_command_copied", { command });

        copyIcon?.classList.add("hidden");
        checkIcon?.classList.remove("hidden");
        clearTimeout(resetTimer);
        resetTimer = setTimeout(() => {
          checkIcon?.classList.add("hidden");
          copyIcon?.classList.remove("hidden");
        }, COPIED_MS);
      });
    });
  };

  // Fires on initial load and after every view transition.
  document.addEventListener("astro:page-load", wireCopyButtons);
</script>
